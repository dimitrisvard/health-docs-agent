# ---- Anthropic (you already have the key) ----
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# Route through Cloudflare AI Gateway for logging / cost / caching / spend limits:
ANTHROPIC_BASE_URL=https://gateway.ai.cloudflare.com/v1/<CF_ACCOUNT_ID>/<CF_GATEWAY_ID>/anthropic
# Only if you enable "Authenticated Gateway" in Cloudflare:
# CF_AIG_TOKEN=
# Model id (use your configured latest Sonnet):
ANTHROPIC_MODEL=claude-sonnet-4-5

# ---- Database (local: provided by docker-compose, no action needed) ----
DATABASE_URL=postgresql://postgres:postgres@db:5432/app

# ---- Internal service wiring (provided by docker-compose) ----
MCP_URL=http://mcp:8000/mcp

# ---- Embeddings (local model, no key needed) ----
EMBED_MODEL=BAAI/bge-base-en-v1.5

# ---- Observability (optional) ----
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=info

# ---- Cloudflare production (Phase 8, optional) ----
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=
# VECTORIZE_INDEX=health-docs
# D1_DATABASE_ID=
# R2_BUCKET=health-docs
